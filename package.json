{
  "name": "header-grader",
  "version": "0.1.1",
  "description": "Security header grader for local dev — grades your dev server's HTTP security headers and generates the Express/Nginx config to fix them.",
  "keywords": [
    "security",
    "headers",
    "csp",
    "hsts",
    "helmet",
    "middleware",
    "cli",
    "devtools"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "header-grader": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js",
      "require": "./dist/middleware.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "demo:bare": "node test/fixtures/bare-server.mjs",
    "demo:hardened": "node test/fixtures/hardened-server.mjs",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
